Options -Indexes
DirectoryIndex index.php
AddDefaultCharset UTF-8

<IfModule mod_headers.c>
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
SetEnvIf Request_URI "^/downloads/smartvision-tv\.apk$" smartvision_stable_apk
Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=smartvision_stable_apk
Header always set Pragma "no-cache" env=smartvision_stable_apk
</IfModule>

RewriteEngine On
RewriteRule ^api/app/ads-config/?$ api/app/ads-config.php [L,QSA]
RewriteRule ^api/app/ads-events/?$ api/app/ads-events.php [L,QSA]
RewriteRule ^api/app/ads-vast/?$ api/app/ads-vast.php [L,QSA]
RewriteRule ^api/app/anomaly-events/?$ api/app/anomaly-events.php [L,QSA]
RewriteRule ^api/app/behavior-events/?$ api/app/behavior-events.php [L,QSA]
RewriteRule ^api/media/private/libraries/?$ api/media/private/libraries.php [L,QSA]
RewriteRule ^api/media/private/categories/?$ api/media/private/categories.php [L,QSA]
RewriteRule ^api/media/private/items/?$ api/media/private/items.php [L,QSA]
RewriteRule ^api/media/private/item/?$ api/media/private/item.php [L,QSA]
RewriteRule ^api/media/private/playback/?$ api/media/private/playback.php [L,QSA]
RewriteRule ^api/media/private/providers/health/?$ api/media/private/providers/health.php [L,QSA]
RewriteRule ^api/gammal-webhook/?$ api/gammal-webhook.php [L,QSA]
